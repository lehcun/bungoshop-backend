{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1"
  },
  "reporters": [
    "default",
    [
      "jest-html-reporter",
      {
        "pageTitle": "Báo cáo Kiểm thử API E-Commerce",
        "outputPath": "./test-report.html"
      }
    ]
  ]
}
